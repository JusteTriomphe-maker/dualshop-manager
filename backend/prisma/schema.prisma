generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  nom        String
  email      String   @unique
  password   String
  role       Role     @default(CAISSIER)
  boutiqueId String?
  boutique   Boutique? @relation(fields: [boutiqueId], references: [id])
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())
  ventes     Vente[]
}

model Boutique {
  id       String    @id @default(uuid())
  nom      String
  type     TypeBoutique
  users    User[]
  produits Produit[]
  ventes   Vente[]
  clients  Client[]
}

model Produit {
  id          String    @id @default(uuid())
  nom         String
  code        String?   @unique
  prix        Float
  coutAchat   Float?
  stockActuel Int       @default(0)
  stockMin    Int       @default(5)
  categorie   String?
  boutiqueId  String
  boutique    Boutique  @relation(fields: [boutiqueId], references: [id])
  actif       Boolean   @default(true)
  lignesVente LigneVente[]
  mouvements  MouvementStock[]
  dettesFournisseur DetteFournisseur[]
}

model Vente {
  id              String       @id @default(uuid())
  numero          String       @unique
  boutiqueId      String
  boutique        Boutique     @relation(fields: [boutiqueId], references: [id])
  caissierIId     String
  caissier        User         @relation(fields: [caissierIId], references: [id])
  lignes          LigneVente[]
  total           Float
  modePaiement    ModePaiement @default(ESPECES)
  statut          StatutVente  @default(COMPLETEE)
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  detteClient     DetteClient?
  numeroTable     String?
  createdAt       DateTime     @default(now())
  synchedAt       DateTime?
  sourceDevice    String?
  receiptPrinted  Boolean      @default(false)
}

model LigneVente {
  id        String  @id @default(uuid())
  venteId   String
  vente     Vente   @relation(fields: [venteId], references: [id])
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])
  quantite  Int
  prixUnit  Float
  sousTotal Float
}

model MouvementStock {
  id            String        @id @default(uuid())
  produitId     String
  produit       Produit       @relation(fields: [produitId], references: [id])
  fournisseurId String?
  fournisseur   Fournisseur?  @relation(fields: [fournisseurId], references: [id])
  type          TypeMouvement
  quantite      Int
  raison        String?
  userId        String
  createdAt     DateTime      @default(now())
}

enum Role {
  DG
  GERANT
  CAISSIER
}

enum TypeBoutique {
  EPICERIE
  RESTAUBAR
}

enum ModePaiement {
  ESPECES
  MOBILE_MONEY
  CARTE
  CREDIT
}

enum StatutVente {
  COMPLETEE
  ANNULEE
  EN_ATTENTE
}

enum TypeMouvement {
  ENTREE
  SORTIE
  AJUSTEMENT
  PERTE
}

model Client {
  id        String   @id @default(uuid())
  nom       String
  telephone String?
  adresse   String?
  boutiqueId String
  boutique  Boutique @relation(fields: [boutiqueId], references: [id])
  createdAt DateTime @default(now())
  ventes    Vente[]
  dettes    DetteClient[]
}

model Fournisseur {
  id         String             @id @default(uuid())
  nom        String
  telephone  String?
  contact    String?
  createdAt  DateTime           @default(now())
  dettes     DetteFournisseur[]
  mouvements MouvementStock[]
}


model DetteClient {
  id            String          @id @default(uuid())
  clientId      String
  client        Client          @relation(fields: [clientId], references: [id])
  venteId       String?         @unique
  vente         Vente?          @relation(fields: [venteId], references: [id])
  montant       Float
  montantRestant Float
  description   String?
  dateEcheance  DateTime?
  statut        DetteStatut     @default(IMPAYEE)
  createdAt     DateTime        @default(now())
  paiements     PaiementClient[]
}

model DetteFournisseur {
  id            String             @id @default(uuid())
  fournisseurId String
  fournisseur   Fournisseur        @relation(fields: [fournisseurId], references: [id])
  produitId     String?
  produit       Produit?           @relation(fields: [produitId], references: [id])
  montantDu     Float
  montantPaye   Float              @default(0)
  description   String?
  dateEcheance  DateTime?
  statut        DetteStatut        @default(IMPAYEE)
  createdAt     DateTime           @default(now())
  paiements     PaiementFournisseur[]
}

model PaiementClient {
  id            String     @id @default(uuid())
  detteClientId String
  dette         DetteClient @relation(fields: [detteClientId], references: [id])
  montant       Float
  modePaiement  ModePaiement @default(ESPECES)
  datePaiement  DateTime   @default(now())
  createdAt     DateTime   @default(now())
}

model PaiementFournisseur {
  id              String         @id @default(uuid())
  detteFournisseurId String
  dette           DetteFournisseur @relation(fields: [detteFournisseurId], references: [id])
  montant         Float
  datePaiement    DateTime       @default(now())
  createdAt       DateTime       @default(now())
}

enum DetteStatut {
  IMPAYEE
  PARTIELLE
  PAYEE
}
